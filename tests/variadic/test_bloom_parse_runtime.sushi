# Bloom (spread/forwarding): move an existing i32[] into a variadic ...i32 slot
# with the postfix `arr...` form. The array is consumed (moved) into the callee.
# EXPECT_STDOUT_CONTAINS: sum = 6
fn sum(...i32 nums) i32:
    let i32 total = 0
    foreach(n in nums.iter()):
        total := total + n
    return Result.Ok(total)

fn main() i32:
    let i32[] xs = from([1, 2, 3])
    let i32 s = sum(xs...).realise(0)
    println("sum = {s}")
    return Result.Ok(0)
