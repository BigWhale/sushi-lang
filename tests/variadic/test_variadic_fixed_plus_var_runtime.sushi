# Fixed prefix parameter plus a trailing variadic: log_all(prefix, ...values).
# EXPECT_STDOUT_EXACT: "val: 10\nval: 20\nval: 30\n"
fn log_all(string prefix, ...i32 values) ~:
    foreach(v in values.iter()):
        println("{prefix}: {v}")
    return Result.Ok(~)

fn main() i32:
    log_all("val", 10, 20, 30)
    return Result.Ok(0)
