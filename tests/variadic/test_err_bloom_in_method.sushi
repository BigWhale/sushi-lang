# A bloom `arr...` is not allowed in a method call (methods cannot be variadic). -> CE0120.
# (Guards the backend against an unhandled Spread reaching codegen when a method's
# parameter happens to be an array type.)
# EXPECT_ERROR_CODE: CE0120
fn main() i32:
    let i32[] a = from([1, 2])
    let i32[] b = from([3, 4])
    a.push(b...)
    return Result.Ok(0)
