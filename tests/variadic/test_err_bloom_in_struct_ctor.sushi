# A bloom `arr...` is not a struct-construction argument. -> CE0120.
# (Guards the backend against an unhandled Spread reaching codegen when a struct
# field type happens to be an array type.)
# EXPECT_ERROR_CODE: CE0120
struct Holder:
    i32[] xs

fn main() i32:
    let i32[] a = from([1, 2])
    let Holder h = Holder(a...)
    return Result.Ok(0)
