# A bloom argument `arr...` is only allowed into a variadic '...T' slot. Blooming
# into a non-variadic function is CE0120.
# EXPECT_ERROR_CODE: CE0120
fn takes_one(i32 a) i32:
    return Result.Ok(a)

fn main() i32:
    let i32[] xs = from([1, 2, 3])
    let i32 r = takes_one(xs...).realise(0)
    return Result.Ok(0)
