# E2 (#71): repeated same-enum-type pack args. `Color.Red()`/`Color.Green()`
# parse to DotCalls (pre-lowering enum constructors); Pass 1.5 must infer their
# enum type so the pack instantiation ('show_all', (Color, Color)) registers.
# EXPECT_STDOUT_EXACT: "red\ngreen\n"
perk Display:
    fn display() string

enum Color:
    Red()
    Green()

extend Color with Display:
    fn display() string:
        match self:
            Color.Red() -> return "red"
            Color.Green() -> return "green"

fn show_all<...Ts: Display>(...Ts args) ~:
    expand(a in args):
        println(a.display())
    return Result.Ok(~)

fn main() i32:
    show_all(Color.Red(), Color.Green())
    return Result.Ok(0)
