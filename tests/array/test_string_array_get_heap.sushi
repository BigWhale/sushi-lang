# Minimal reproducer: .get() on a dynamic array of strings (string[]).
# The heap-allocated element is wrapped in Maybe<string> and unwrapped.
# Quarantined from runtime validation: corrupts the heap on glibc
# (SIGABRT, "sysmalloc: corrupted top size") while passing on macOS.
# Independent of index type and of the ?? operator; i32[] is unaffected.
# See GitHub issue (linked in tests/enhanced_test_runner.py quarantine note).
# TEST_TYPE: runtime
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: hello

fn run_test() i32:
    let string[] arr = from(["hello", "world"])
    let i32 idx = 0
    let string v = arr.get(idx)??
    print("{v}")
    return Result.Ok(0)

fn main() i32:
    return Result.Ok(run_test().realise(99))
