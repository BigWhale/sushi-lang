# Regression test for issue #24: .get() on a dynamic array of strings (string[]).
# The heap-allocated element is wrapped in Maybe<string> and unwrapped. This used
# to corrupt the heap on glibc (SIGABRT, "sysmalloc: corrupted top size") because
# string[] was allocated using the 12-byte string data size while GEP strides by
# the 16-byte alloc size; i32[] was unaffected.
# TEST_TYPE: runtime
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "hello"

fn run_test() i32:
    let string[] arr = from(["hello", "world"])
    let i32 idx = 0
    let string v = arr.get(idx)??
    print("{v}")
    return Result.Ok(0)

fn main() i32:
    return Result.Ok(run_test().realise(99))
