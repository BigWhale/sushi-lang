# Use-after-move (#134): placing an owning struct into an array literal moves it
# (the array-literal element is an ownership sink); reusing the source is CE2405.
# EXPECT_ERROR_CODE: CE2405
# EXPECT_STDERR_CONTAINS: was moved here

struct Buffer:
    i32[] data

fn main() i32:
    let Buffer a = Buffer(data: from([1, 2, 3]))
    let Buffer[] arr = from([a])
    let i32 n = a.data.len()
    return Result.Ok(0)
