# TEST_TYPE: error
# EXPECT_ERROR_CODE: CE0052
# An array whose elements transitively contain a dynamic array cannot be hashed.
#
# This test used to declare `i32[2][2] data`. A true nested array type is not
# expressible, so the PARSER rejected it and the compiler never reached the hash
# check -- the test passed on an unrelated syntax error and CE0052 went untested.
# It now uses the shape the restriction is actually about: Row[] where Row has an
# i32[] field. A lone Row, or a plain i32[], hashes fine.

struct Row:
    i32[] cells

fn main() i32:
    let Row[] rows = from([Row(from([1, 2]))])
    let u64 hash = rows.hash()
    println("{hash}")
    return Result.Ok(0)
