# EXPECT_STDOUT_CONTAINS: With break:
# EXPECT_STDOUT_CONTAINS: With continue:
# EXPECT_STDOUT_CONTAINS: 9
fn main() i32:
    println("With break:")
    foreach(i in 0..10):
        if (i == 5):
            break
        println(i)

    println("With continue:")
    foreach(i in 0..10):
        if (i % 2 == 0):
            continue
        println(i)

    return Result.Ok(0)
