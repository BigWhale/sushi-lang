# First-class functions: a List<fn(i32) -> i32> dispatch table, iterated with
# foreach and called through each element. 10 -> +1 -> +2 = 13.
# EXPECT_STDOUT_EXACT: "13\n"
fn add_one(i32 x) i32:
    return Result.Ok(x + 1)

fn add_two(i32 x) i32:
    return Result.Ok(x + 2)

fn dispatch(List<fn(i32) -> i32> ops, i32 v) i32:
    let i32 acc = v
    foreach(f in ops.iter()):
        acc := f(acc)??
    return Result.Ok(acc)

fn main() i32:
    let List<fn(i32) -> i32> ops = List.new()
    ops.push(add_one)
    ops.push(add_two)
    # ops is moved into dispatch(), which owns and frees the list (and its fn values)
    # at scope exit -- no explicit ops.free() here (that would be a use-after-move).
    let i32 out = dispatch(ops, 10).realise(0)
    println(out)
    return Result.Ok(0)
