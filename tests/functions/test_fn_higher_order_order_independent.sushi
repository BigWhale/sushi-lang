# A higher-order fn that calls through its fn-typed parameter must compile
# regardless of definition order (apply defined BEFORE double). Bug C / CE0055.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "Result: 84\n"

fn apply(fn(i32) -> i32 f, i32 x) i32:
  let i32 r = f(x)??
  return Result.Ok(r)

fn double(i32 x) i32:
  return Result.Ok(x * 2)

fn main() i32:
  let fn(i32) -> i32 g = double
  let i32 out = apply(g, 42).realise(0)
  if (out != 84):
    return Result.Ok(1)
  println("Result: {out}")
  return Result.Ok(0)
