# Call-through arbitrary expressions that evaluate to a function value: a List get-out
# `fns.get(0)??(x)` and a parenthesized expression `(fns.get(0)??)(x)`. Both call inc:
# inc(10) + inc(20) = 11 + 21 = 32.
# EXPECT_STDOUT_EXACT: "32\n"
fn inc(i32 x) i32:
    return Result.Ok(x + 1)

fn run() i32:
    let List<fn(i32) -> i32> fns = List.new()
    fns.push(inc)
    let i32 a = fns.get(0)??(10)??
    let i32 b = (fns.get(0)??)(20)??
    return Result.Ok(a + b)

fn main() i32:
    println(run().realise(-1))
    return Result.Ok(0)
