# Test storing enum values in a List<EnumType>.
# Regression test for issue #33: List.destroy() on a List<EnumType> used to
# crash the compiler with "'IntType' object has no attribute 'gep'" because the
# destroy-elements loop passed the loaded element value (not a pointer) to
# emit_value_destructor().
#
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "List enum: passed\n"

enum Color:
    Red
    Green
    Blue

fn main() i32:
    let List<Color> colors = List.new()
    colors.push(Color.Red())
    colors.push(Color.Green())

    let i32 len = colors.len()
    if (len != 2):
        println("FAIL: expected 2 got {len}")
        return Result.Ok(1)

    colors.destroy()
    println("List enum: passed")
    return Result.Ok(0)
