# Test HashMap with enum-string values and .free(): verifies RAII cleanup of
# string-carrying enum variants stored in the HashMap heap
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "Label 1: alpha\nHashMap free: done\n"

use <collections/hashmap>

enum Label:
    Name(string)
    Code(i32)

fn main() i32:
    let HashMap@(i32, Label) labels = HashMap.new()
    labels.insert(1, Label.Name("alpha"))
    labels.insert(2, Label.Code(42))
    labels.insert(3, Label.Name("beta"))

    let Maybe@(Label) l = labels.get(1)
    match l:
        Maybe.Some(label) ->
            match label:
                Label.Name(s) ->
                    println("Label 1: {s}")
                Label.Code(n) ->
                    println("FAIL: expected Name not Code({n})")
                    return Result.Ok(1)
        Maybe.None() ->
            println("FAIL: label 1 not found")
            return Result.Ok(1)

    labels.free()
    println("HashMap free: done")
    return Result.Ok(0)
