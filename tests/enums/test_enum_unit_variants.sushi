# Test basic unit-variant enum: construction, match on each variant, printing
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: north east south west

enum Direction:
    North
    South
    East
    West

fn direction_name(Direction d) string:
    match d:
        Direction.North ->
            return Result.Ok("north")
        Direction.South ->
            return Result.Ok("south")
        Direction.East ->
            return Result.Ok("east")
        Direction.West ->
            return Result.Ok("west")

fn main() i32:
    let Direction d1 = Direction.North()
    let Direction d2 = Direction.East()
    let Direction d3 = Direction.South()
    let Direction d4 = Direction.West()

    let string n1 = direction_name(d1).realise("?")
    let string n2 = direction_name(d2).realise("?")
    let string n3 = direction_name(d3).realise("?")
    let string n4 = direction_name(d4).realise("?")

    println("{n1} {n2} {n3} {n4}")
    return Result.Ok(0)
