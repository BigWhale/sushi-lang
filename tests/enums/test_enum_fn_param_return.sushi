# Test enum used as function parameter and return type
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: Enum param/return: all passed

enum Token:
    Number(i32)
    Plus
    Minus
    Star

fn is_operator(Token t) bool:
    match t:
        Token.Plus ->
            return Result.Ok(true)
        Token.Minus ->
            return Result.Ok(true)
        Token.Star ->
            return Result.Ok(true)
        Token.Number(_) ->
            return Result.Ok(false)

fn negate(Token t) Token:
    match t:
        Token.Plus ->
            return Result.Ok(Token.Minus())
        Token.Minus ->
            return Result.Ok(Token.Plus())
        Token.Star ->
            return Result.Ok(Token.Star())
        Token.Number(n) ->
            return Result.Ok(Token.Number(0 - n))

fn get_value(Token t) i32:
    match t:
        Token.Number(n) ->
            return Result.Ok(n)
        _ ->
            return Result.Ok(0)

fn main() i32:
    let Token t1 = Token.Number(42)
    let Token t2 = Token.Plus()

    let bool is_op1 = is_operator(t1).realise(true)
    let bool is_op2 = is_operator(t2).realise(false)

    if (is_op1):
        println("FAIL: Number is not operator")
        return Result.Ok(1)
    if (not is_op2):
        println("FAIL: Plus is operator")
        return Result.Ok(1)

    let Token neg = negate(t1).realise(Token.Number(0))
    let i32 v = get_value(neg).realise(0)
    if (v != -42):
        println("FAIL: expected -42 got {v}")
        return Result.Ok(1)

    println("Enum param/return: all passed")
    return Result.Ok(0)
