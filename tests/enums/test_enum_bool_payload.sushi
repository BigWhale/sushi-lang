# Test enum variant with bool associated data: construct and read via match
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: on with true
# EXPECT_STDOUT_CONTAINS: off

enum Toggle:
    On(bool)
    Off

fn describe_toggle(Toggle t) string:
    match t:
        Toggle.On(flag) ->
            if (flag):
                return Result.Ok("on with true")
            return Result.Ok("on with false")
        Toggle.Off ->
            return Result.Ok("off")

fn main() i32:
    let Toggle t1 = Toggle.On(true)
    let string s1 = describe_toggle(t1).realise("error")

    let Toggle t2 = Toggle.Off()
    let string s2 = describe_toggle(t2).realise("error")

    println("{s1}")
    println("{s2}")

    if (s1 != "on with true"):
        return Result.Ok(1)
    if (s2 != "off"):
        return Result.Ok(1)

    return Result.Ok(0)
