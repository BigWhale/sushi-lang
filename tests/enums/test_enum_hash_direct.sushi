# Test calling .hash() directly on an enum value.
# Regression test for issue #32: calling .hash() on an inline enum construction
# used to crash the compiler with CE0019 ("cannot determine language type for
# LLVM type: {i32, [1 x i8]}") because the receiver's enum semantic type was not
# recovered, so the dispatcher fell back to mapping the enum LLVM layout.
#
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: Unit enum hash: passed

enum Suit:
    Hearts
    Diamonds
    Clubs
    Spades

fn main() i32:
    let u64 h1 = Suit.Hearts().hash()
    let u64 h2 = Suit.Spades().hash()
    if (h1 == h2):
        println("FAIL: different variants have same hash")
        return Result.Ok(1)
    println("Unit enum hash: passed")
    return Result.Ok(0)
