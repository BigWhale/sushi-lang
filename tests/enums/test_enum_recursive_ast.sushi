# Test recursive expression AST enum with 5 variants: Num, Add, Sub, Mul, Neg
# Validates correct arithmetic evaluation and RAII cleanup of Own<Expr> nodes
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "AST eval: 56\n"

enum Expr:
    Num(i32)
    Add(Own<Expr>, Own<Expr>)
    Sub(Own<Expr>, Own<Expr>)
    Mul(Own<Expr>, Own<Expr>)
    Neg(Own<Expr>)

fn eval(Expr e) i32:
    match e:
        Expr.Num(n) ->
            return Result.Ok(n)
        Expr.Add(Own(l), Own(r)) ->
            let i32 lv = eval(l)??
            let i32 rv = eval(r)??
            return Result.Ok(lv + rv)
        Expr.Sub(Own(l), Own(r)) ->
            let i32 lv = eval(l)??
            let i32 rv = eval(r)??
            return Result.Ok(lv - rv)
        Expr.Mul(Own(l), Own(r)) ->
            let i32 lv = eval(l)??
            let i32 rv = eval(r)??
            return Result.Ok(lv * rv)
        Expr.Neg(Own(x)) ->
            let i32 xv = eval(x)??
            return Result.Ok(0 - xv)

fn main() i32:
    # Build: (3 + 4) * (10 - 2) = 7 * 8 = 56
    let Own<Expr> n3 = Own.alloc(Expr.Num(3))
    let Own<Expr> n4 = Own.alloc(Expr.Num(4))
    let Own<Expr> n10 = Own.alloc(Expr.Num(10))
    let Own<Expr> n2 = Own.alloc(Expr.Num(2))

    let Own<Expr> add = Own.alloc(Expr.Add(n3, n4))
    let Own<Expr> sub = Own.alloc(Expr.Sub(n10, n2))
    let Expr root = Expr.Mul(add, sub)

    let i32 result = eval(root).realise(-1)
    if (result != 56):
        println("FAIL: expected 56 got {result}")
        return Result.Ok(1)

    println("AST eval: {result}")
    return Result.Ok(0)
