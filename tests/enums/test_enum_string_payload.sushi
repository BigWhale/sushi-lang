# Test enum variant with string associated data: construct and read via match
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "Hello, world!\nNo message\nGoodbye, Alice!\n"

enum Message:
    Hello(string)
    Goodbye(string)
    Empty

fn describe(Message m) string:
    match m:
        Message.Hello(name) ->
            return Result.Ok("Hello, {name}!")
        Message.Goodbye(name) ->
            return Result.Ok("Goodbye, {name}!")
        Message.Empty ->
            return Result.Ok("No message")

fn main() i32:
    let Message m1 = Message.Hello("world")
    let string s1 = describe(m1).realise("error")
    println("{s1}")

    let Message m2 = Message.Empty()
    let string s2 = describe(m2).realise("error")
    println("{s2}")

    let Message m3 = Message.Goodbye("Alice")
    let string s3 = describe(m3).realise("error")
    println("{s3}")

    if (s1 != "Hello, world!"):
        return Result.Ok(1)
    if (s2 != "No message"):
        return Result.Ok(1)
    if (s3 != "Goodbye, Alice!"):
        return Result.Ok(1)

    return Result.Ok(0)
