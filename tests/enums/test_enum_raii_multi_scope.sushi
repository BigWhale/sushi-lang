# Test RAII: multiple enum variants (including string-holding) go out of scope
# cleanly. The repeated allocations verify no heap corruption occurs.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "RAII enum scope: 43\n"

enum Kind:
    Alpha(string)
    Beta(i32)
    Gamma

fn process_kind(Kind k) i32:
    match k:
        Kind.Alpha(_) ->
            return Result.Ok(1)
        Kind.Beta(n) ->
            return Result.Ok(n)
        Kind.Gamma ->
            return Result.Ok(0)

fn scope_test() i32:
    let Kind k1 = Kind.Alpha("hello from scope")
    let Kind k2 = Kind.Beta(42)
    let Kind k3 = Kind.Gamma()

    let i32 r1 = process_kind(k1).realise(0)
    let i32 r2 = process_kind(k2).realise(0)
    let i32 r3 = process_kind(k3).realise(0)
    # k1 (with string), k2, k3 all freed at scope end
    return Result.Ok(r1 + r2 + r3)

fn main() i32:
    let i32 result = scope_test().realise(0)
    # r1=1, r2=42, r3=0 => 43
    if (result != 43):
        println("FAIL: expected 43 got {result}")
        return Result.Ok(1)
    println("RAII enum scope: {result}")
    return Result.Ok(0)
