# Test recursive enum (string-keyed linked list) using Own<T> heap allocation
# Validates length counting via recursion and RAII cleanup of Own<T> nodes
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "StrList length: 2\n"

enum StrList:
    Nil
    Cons(string, Own@(StrList))

fn count(StrList lst) i32:
    match lst:
        StrList.Nil ->
            return Result.Ok(0)
        StrList.Cons(_, Own(tail)) ->
            let i32 n = count(tail)??
            return Result.Ok(1 + n)

fn main() i32:
    let Own@(StrList) n2 = Own.alloc(StrList.Nil())
    let Own@(StrList) n1 = Own.alloc(StrList.Cons("world", n2))
    let StrList lst = StrList.Cons("hello", n1)

    let i32 len = count(lst).realise(0)
    if (len != 2):
        println("FAIL: expected 2 got {len}")
        return Result.Ok(1)

    println("StrList length: {len}")
    return Result.Ok(0)
