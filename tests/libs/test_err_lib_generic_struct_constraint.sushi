# Consumer instantiates the library's constrained generic struct Ranked<T: Ord>
# at a type with no Ord impl. The constraint is re-checked relative to the
# consumer's perk impls during struct monomorphization, so it must reject this
# with CE4006 - proving consumer-relative constraint re-checking applies to a
# library-shipped generic TYPE template, not just generic functions.
# EXPECT_ERROR_CODE: CE4006

use <lib/generic_types_lib>

struct Widget:
    i32 id

fn main() i32:
    let Ranked@(Widget) r = Ranked(Widget(1))
    println(r.value.id)
    return Result.Ok(0)
