# C1 (P2-5 Phase 3): the library's constrained generic max_of<T: Ord> is
# instantiated at TWO types (i32 and i64) in one consumer, each with its own
# consumer-supplied Ord implementation. Removing either extend block makes the
# corresponding instantiation fail CE4006, so both witnesses are exercised.
# (Values stay within i32 range: i64 arithmetic on out-of-range values is a
# pre-existing, unrelated compiler limitation.)
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: "7"
# EXPECT_STDOUT_CONTAINS: "1000000"

use <lib/generics_lib>

# The Ord perk definition ships with the library; the consumer supplies one
# implementation per instantiation type. The perk signature is fixed at
# gt(i32 other), so the i64 impl casts before comparing.
extend i32 with Ord:
    fn gt(i32 other) bool:
        return self > other

extend i64 with Ord:
    fn gt(i32 other) bool:
        return self > (other as i64)

fn max32() i32:
    let i32 m = max_of(3, 7)??
    return Result.Ok(m)

fn max64() i64:
    let i64 big = 1000000 as i64
    let i64 small = 2 as i64
    let i64 m = max_of(big, small)??
    return Result.Ok(m)

fn main() i32:
    let i32 r32 = max32().realise(99)
    println(r32)
    let i64 r64 = max64().realise(99 as i64)
    println(r64)
    return Result.Ok(0)
