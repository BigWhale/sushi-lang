# generic_types_lib.sushi - exports generic STRUCT and ENUM templates.
#
# P2-5 Phase 1 (C3): generic structs/enums ship in the .slib as re-parsable
# templates and are monomorphized at the consumer's own types - the same
# mechanism already used for generic functions.

# Perk referenced by the constrained generic struct below. A generic's
# type-param constraint causes its perk DEFINITION to ship with the templates.
perk Ord:
    fn gt(i32 other) bool

# Simple generic struct container.
struct Box<T>:
    T value

# Generic optional enum (distinct name to avoid the builtin Maybe).
enum Opt<T>:
    Nope
    Yep(T)

# Co-shipped nested generics: Holder<T> has a field of another exported generic
# Cell<T>. Both ship as templates and must instantiate transitively.
struct Cell<T>:
    T item

struct Holder<T>:
    Cell<T> cell

# NOTE on recursive generic enums (e.g. `enum Tree<T>: Leaf(T), Node(Own<Tree<T>>)`):
# an old comment here claimed instantiating one infinite-loops the monomorphizer.
# That is stale - T2.5's tie-the-knot fixed it, and the shape was re-verified
# 2026-07-16 to compile and run both in-program AND across a .slib boundary
# (see docs/design/libraries.md). Not exported here only to keep this fixture
# focused on the plain/constrained template paths.

# Constrained generic struct: proves consumer-relative CE4006 re-checking for a
# library-shipped generic TYPE template (not just a generic function).
struct Ranked<T: Ord>:
    T value
