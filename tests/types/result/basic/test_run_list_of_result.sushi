# Regression for #184: a Result<T,E> must be usable as a List element.
# It used to fail with CE0045, 'generic type Result<string, StdError> not found in enum or
# struct table'. Result was explicitly skipped by the monomorphizer (semantic_analyzer.py),
# so its concrete EnumType was never interned and the List element type could not resolve.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: "len = 2"
# EXPECT_STDOUT_CONTAINS: "first ok = true"
# EXPECT_NO_LEAKS: true

fn main() i32:
    let List@(Result@(string, StdError)) l = List.new()
    l.push(Result.Ok("alpha"))
    l.push(Result.Err(StdError.Error))
    println("len = {l.len()}")

    let Maybe@(Result@(string, StdError)) head = l.get(0)
    match head:
        Maybe.Some(r) -> println("first ok = {r.is_ok()}")
        Maybe.None() -> println("first ok = missing")
    return Result.Ok(0)
