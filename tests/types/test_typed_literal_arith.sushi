# Operand-driven literal typing: a bare literal takes its concrete sibling's type
# in arithmetic/bitwise/comparison (Bug E / PR 2c).
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: "arith ok"

fn main() i32:
  let u8 a = 10
  let u8 sum = a + 1
  let u8 masked = a & 0x0F
  let u8 shifted = a << 1
  if (sum != 11 as u8):
    return Result.Ok(1)
  if (masked != 10 as u8):
    return Result.Ok(2)
  if (shifted != 20 as u8):
    return Result.Ok(3)
  if (a == 10):
    if (a > 5):
      println("arith ok")
      return Result.Ok(0)
  return Result.Ok(4)
