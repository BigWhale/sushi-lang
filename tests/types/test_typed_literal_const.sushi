# Context-typed numeric literals in const declarations (Bug E / PR 2a).
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: "const literals ok"

const u8 MAXB = 200
const i64 BIG = 5
const u32 MASK = 0xFF

fn main() i32:
  if (MAXB != 200 as u8):
    return Result.Ok(1)
  if (BIG != 5 as i64):
    return Result.Ok(2)
  if (MASK != 255 as u32):
    return Result.Ok(3)
  println("const literals ok")
  return Result.Ok(0)
