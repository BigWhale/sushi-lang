# TEST_TYPE: runtime
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "15\n5\n50\n2\n0\nMostly Harmless\n"
# Same-type small integer comparisons and arithmetic.
fn main() i32:
  let i8 a = 10 as i8
  let i8 b = 5 as i8

  # Comparisons
  let bool eq = a == a
  let bool gt = a > b
  let bool lt = b < a

  # Arithmetic. This block was previously omitted; the defect it avoided no longer
  # exists, and leaving it out only removed coverage.
  let i8 sum = a + b
  let i8 diff = a - b
  let i8 prod = a * b
  let i8 quot = a / b
  let i8 rem = a % b
  println(sum)
  println(diff)
  println(prod)
  println(quot)
  println(rem)

  if (eq and gt and lt and sum == (15 as i8) and diff == (5 as i8)
      and prod == (50 as i8) and quot == (2 as i8) and rem == (0 as i8)):
    println("Mostly Harmless")
    return Result.Ok(0)

  return Result.Ok(1)
