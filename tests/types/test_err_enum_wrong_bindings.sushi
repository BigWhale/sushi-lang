# Error test: wrong number of pattern bindings
# EXPECT_ERROR_CODE: CE2044
enum Status:
    Success(i32)
    Failure(i32)

fn process(Status r) i32:
    match r:
        # Error: Success has 1 field but we try to bind 2 variables
        Status.Success(a, b) ->
            return Result.Ok(a + b)
        Status.Failure(code) ->
            return Result.Ok(code)

fn main() i32:
    let Status r = Status.Success(42)
    return Result.Ok(process(r))
