# EXPECT_STDOUT_EXACT: "Inner array length before: 1\nInner array value before: 42\nOuter.data array length after: 1\nOuter.data array value after: 42\nInner array length after nesting: 1\nInner array value after nesting: 42\n"
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_NO_LEAKS: true
# #134: nesting keeps the source usable by cloning it explicitly into the outer struct.

struct Inner:
    i32[] values

struct Outer:
    Inner data

fn run_test() i32:
    # Create inner struct with dynamic array
    let Inner inner = Inner(new())
    inner.values.push(42)

    println("Inner array length before: {inner.values.len()}")
    println("Inner array value before: {inner.values.get(0)??}")

    # Pass a clone of inner to the outer constructor so inner stays usable below.
    let Outer outer = Outer(inner.clone())

    println("Outer.data array length after: {outer.data.values.len()}")
    println("Outer.data array value after: {outer.data.values.get(0)??}")

    # Check if inner was affected
    println("Inner array length after nesting: {inner.values.len()}")
    if (inner.values.len() > 0):
        println("Inner array value after nesting: {inner.values.get(0)??}")

    return Result.Ok(0)

fn main() i32:
    let i32 result = run_test().realise(99)
    return Result.Ok(result)
