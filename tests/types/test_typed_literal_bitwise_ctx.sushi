# Top-down context typing flows the expected type into binary-op operands
# (Bug E / PR 2c), so a const/let bitwise expression of bare literals is typed.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: "bitwise ok"

const u32 FLAGS = 0x01 | 0x02 | 0x04

fn main() i32:
  let u32 m = 0x01 | 0x02
  if (FLAGS != 7 as u32):
    return Result.Ok(1)
  if (m != 3 as u32):
    return Result.Ok(2)
  println("bitwise ok")
  return Result.Ok(0)
