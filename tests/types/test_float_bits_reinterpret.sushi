# EXPECT_RUNTIME_EXIT: 0
# TEST_TYPE: runtime
# EXPECT_STDOUT_CONTAINS: "f64_bits=4614253070214989087"
# EXPECT_STDOUT_CONTAINS: "f32_bits=1069547520"
# EXPECT_STDOUT_CONTAINS: "f64_val=3.14"
# EXPECT_STDOUT_CONTAINS: "f32_val=1.5"
# EXPECT_STDOUT_CONTAINS: "roundtrip=2.71828"
#
# Float bit-reinterpret primitives: f64/f32 .to_bits() and .from_bits().
# Byte-for-byte compatible with IEEE-754 (verified against Python struct).
fn main() i32:
    # to_bits(): expose the raw IEEE-754 encoding (NOT a value cast)
    let f64 pi = 3.14
    let u64 pi_bits = pi.to_bits()
    println("f64_bits={pi_bits}")

    let f32 half3 = 1.5 as f32
    let u32 half3_bits = half3.to_bits()
    println("f32_bits={half3_bits}")

    # from_bits(): reconstruct a float from its bit pattern
    let f64 back = f64.from_bits(pi_bits)
    println("f64_val={back}")

    let f32 back32 = f32.from_bits(half3_bits)
    println("f32_val={back32}")

    # round-trip an independent constant through both directions
    let f64 e = 2.71828
    let f64 rt = f64.from_bits(e.to_bits())
    println("roundtrip={rt}")

    return Result.Ok(0)
