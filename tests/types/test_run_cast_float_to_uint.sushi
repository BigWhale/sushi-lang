# Guards PLAN.md T1.1: a float-to-unsigned cast must emit `fptoui`, not `fptosi`.
# 3000000000.0 exceeds i32::MAX, so fptosi saturates to 2147483647.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "3000000000\n"
fn main() i32:
    let f64 f = 3000000000.0
    let u32 u = f as u32
    println(u)
    return Result.Ok(0)
