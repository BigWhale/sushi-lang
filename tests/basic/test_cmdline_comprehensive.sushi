# TEST_TYPE: runtime
# CMD_ARGS: Thanks for all the fish
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: Total arguments: 6

# args is main's borrowed view of C argv -- borrow it downstream (never move it by value).
fn run_test(&peek string[] args) i32:
    println("Total arguments: {args.len()}")

    let i32 i = 0
    while (i < args.len()):
        println("Argument {i}: {args.get(i)??}")
        i := i + 1

    # Test that we can use array methods normally
    if (args.len() > 0):
        println("First argument: {args.get(0)??}")

    return Result.Ok(0)

fn main(string[] args) i32:
    # Touch args directly (avoids the borrow-only CW1003 lint); the reader borrows it.
    if (args.len() > 0):
        let i32 result = run_test(&peek args).realise(99)
        return Result.Ok(result)
    return Result.Ok(0)
