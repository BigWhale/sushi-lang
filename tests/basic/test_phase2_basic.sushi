# EXPECT_STDOUT_EXACT: "Point hash: 14687699039417897699\n"
# Test that basic struct hashing still works with dual registration (Pass 0 + Pass 1.8)

struct Point:
    i32 x
    i32 y

fn main() i32:
    let Point p = Point(10, 20)
    let u64 h = p.hash()
    println("Point hash: {h}")
    return Result.Ok(0)
