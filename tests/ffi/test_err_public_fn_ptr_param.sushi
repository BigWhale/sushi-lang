# FFI: a `public fn` may not expose a foreign `ptr` parameter across a unit boundary.
# EXPECT_ERROR_CODE: CE5008
unsafe external "C" as libc because "intentional public ptr exposure":
    fn free(ptr p) ~ = "free"

public fn release(ptr p) ~:
    libc.free(p)
    return Result.Ok(~)

fn main() i32:
    return Result.Ok(0)
