# FFI: foreign `ptr` cannot be a List element (only Result/Maybe carry ptr).
# EXPECT_ERROR_CODE: CE5012
unsafe external "C" as libc because "intentional ptr in List":
    fn malloc(i64 n) ptr = "malloc"

fn main() i32:
    let ptr a = libc.malloc(8 as i64)
    let List@(ptr) handles = List.new()
    handles.push(a)
    return Result.Ok(0)
