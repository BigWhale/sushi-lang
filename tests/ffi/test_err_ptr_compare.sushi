# FFI: a foreign `ptr` is an opaque handle with no comparable identity.
# EXPECT_ERROR_CODE: CE5010
unsafe external "C" as libc because "intentional ptr comparison":
    fn malloc(i64 n) ptr = "malloc"
    fn free(ptr p) ~ = "free"

fn main() i32:
    let ptr a = libc.malloc(8 as i64)
    let ptr b = libc.malloc(8 as i64)
    if (a == b):
        println("same")
    libc.free(a)
    libc.free(b)
    return Result.Ok(0)
