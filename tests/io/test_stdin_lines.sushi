# TEST_TYPE: runtime
# STDIN_INPUT: "First\nSecond\nThird\n"
# EXPECT_STDOUT_EXACT: "Reading lines from stdin:\n  > First\n  > Second\n  > Third\nDone!\n"
# EXPECT_RUNTIME_EXIT: 0
# Test stdin.lines() iterator in foreach loop

use <io/stdio>

fn main() i32:
    stdout.write("Reading lines from stdin:\n")

    foreach(line in stdin.lines()):
        stdout.write("  > ")
        stdout.write(line)
        stdout.write("\n")

    stdout.write("Done!\n")
    return Result.Ok(0)
