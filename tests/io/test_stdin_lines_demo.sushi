# TEST_TYPE: runtime
# STDIN_INPUT: "One\nTwo\nThree\nFour\n"
# EXPECT_STDOUT_EXACT: "=== stdin.lines() Demo ===\nReading lines from stdin until EOF...\n\nLine 1: One\nLine 2: Two\nLine 3: Three\nLine 4: Four\n\nTotal lines read: 4\n"
# EXPECT_RUNTIME_EXIT: 0
# Comprehensive demonstration of stdin.lines() iterator

use <io/stdio>

fn main() i32:
    stdout.write("=== stdin.lines() Demo ===\n")
    stdout.write("Reading lines from stdin until EOF...\n\n")

    let i32 count = 0

    foreach(line in stdin.lines()):
        count := count + 1
        stdout.write("Line ")
        print(count)
        stdout.write(": ")
        stdout.write(line)
        stdout.write("\n")

    stdout.write("\nTotal lines read: ")
    println(count)

    return Result.Ok(0)
