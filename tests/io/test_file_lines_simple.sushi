# Simple test for file.lines() type inference
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: Mostly Harmless
use <io/files>

fn main() i32:
    # Write the file first. This test used to open a test.txt that nothing ever
    # created, so it always took the Err arm and exited 1 without reaching lines().
    let FileResult write_result = open("test_lines_simple.txt", FileMode.Write())
    match write_result:
        FileResult.Ok(out) ->
            out.writeln("Mostly Harmless")
            out.close()
        FileResult.Err(_) ->
            return Result.Err(StdError.Error)

    let FileResult result = open("test_lines_simple.txt", FileMode.Read())
    match result:
        FileResult.Ok(f) ->
            # Just call f.lines() to see if type inference works
            f.lines()
            println("Mostly Harmless")
        FileResult.Err(_) ->
            return Result.Err(StdError.Error)

    return Result.Ok(0)
