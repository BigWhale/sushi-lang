# EXPECT_STDOUT_EXACT: "Interpolated: Life\n"
# EXPECT_RUNTIME_EXIT: 0
struct Pair@(T, U):
    T first
    U second

fn main() i32:
    let Pair@(i32, string) slartibartfast = Pair(42, "Life")
    let Maybe@(Pair@(i32, string)) true_answer = Maybe.Some(slartibartfast)

    let Pair@(i32, string) default_pair = Pair(0, "")
    let Pair@(i32, string) ford = true_answer.realise(default_pair)
    println("Interpolated: {ford.second}")

    return Result.Ok(0)
