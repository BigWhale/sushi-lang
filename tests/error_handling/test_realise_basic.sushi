
# EXPECT_STDOUT_EXACT: "x = 42\ny = 99\n"
# EXPECT_RUNTIME_EXIT: 0
fn get_value() i32:
    return Result.Ok(42)

fn get_error() i32:
    return Result.Err(StdError.Error)

fn main() i32:
    let i32 x = get_value().realise(0)
    let i32 y = get_error().realise(99)

    println("x = {x}")
    println("y = {y}")

    return Result.Ok(0)
