# Copy semantics (#134), spec V5: a MemberAccess source (w.inner) is NOT a bare Name, so
# it keeps the deep copy at a by-value sink -- the continuing owner `w` stays fully usable,
# and both the copy and the original free exactly once (no double-free, no leak).
# EXPECT_STDOUT_EXACT: "in=3 src=3\n"
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_NO_LEAKS: true

struct Buffer:
    i32[] data

struct Wrapper:
    Buffer inner

fn total(Buffer b) i32:
    return Result.Ok(b.data.len())

fn main() i32:
    let Wrapper w = Wrapper(inner: Buffer(data: from([1, 2, 3])))
    let i32 n = total(w.inner).realise(-1)
    println("in={n} src={w.inner.data.len()}")
    return Result.Ok(0)
