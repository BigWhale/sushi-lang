# Regression for #159: a fresh unbound temporary is produced by the `while` CONDITION on every
# iteration, so the leak scales with the iteration count. This is the cell that proves the fix frees
# the temporary PER ITERATION rather than once at scope exit -- and that the destroy is emitted in the
# condition block, where the value actually dominates.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: "i = 3"
# EXPECT_NO_LEAKS: true

fn mk(i32 n) string:
    return Result.Ok("xxxxxxxxxxxx{n}")

fn probe() ~:
    let i32 i = 0
    while (mk(i).is_ok() and i < 3):
        i := i + 1
    println("i = {i}")
    return Result.Ok(~)

fn main() i32:
    probe()
    return Result.Ok(0)
