# EXPECT_STDOUT_EXACT: "a=2 b=2 first=3\n"
# EXPECT_RUNTIME_EXIT: 0
# TEST_TYPE: runtime
# Regression for #158: `.clone()` on an array of owning elements must deep-copy each
# element, not shallow-copy it. Before the fix the cloned element shared the source
# element's heap buffer, so both arrays freed it at scope exit and the process aborted
# (double-free, exit 133). Covers an owning struct; the sibling test covers an owning enum.

struct Buf:
    i32[] data

fn run() i32:
    let Buf[] a = from([Buf(data: from([1, 2, 3])), Buf(data: from([4, 5, 6]))])
    let Buf[] b = a.clone()
    let Buf first = b[0]
    println("a={a.len()} b={b.len()} first={first.data.len()}")
    return Result.Ok(0)

fn main() i32:
    let i32 r = run().realise(1)
    return Result.Ok(r)
