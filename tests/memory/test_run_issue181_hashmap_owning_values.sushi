# Regression for #181, value path: a HashMap<string,string> struct field must deep-clone
# and destroy BOTH the owning key and the owning value of every occupied Entry. Heap
# (interpolated) keys and values exercise the full per-entry clone + destroy walk.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: "len = 2"
# EXPECT_NO_LEAKS: true

use <collections/hashmap>

struct Holder:
    HashMap<string, string> m

fn main() i32:
    let HashMap<string, string> map = HashMap.new()
    map.insert("k1-{'a'}", "v1-{'b'}")
    map.insert("k2-{'c'}", "v2-{'d'}")
    let Holder h = Holder(map)
    map.free()
    println("len = {h.m.len()}")
    return Result.Ok(0)
