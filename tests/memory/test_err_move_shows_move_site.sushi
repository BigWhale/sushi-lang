# Error: use-after-move names BOTH locations -- where the value was used, and
# where it was moved. The move site is the half the user cannot see.
# EXPECT_ERROR_CODE: CE2405
# EXPECT_STDERR_CONTAINS: was moved here

fn take(i32[] a) i32:
    return Result.Ok(a.len() as i32)

fn main() i32:
    let i32[] xs = from([1, 2, 3])
    let Result<i32, StdError> first = take(xs)
    let Result<i32, StdError> second = take(xs)
    return Result.Ok(0)
