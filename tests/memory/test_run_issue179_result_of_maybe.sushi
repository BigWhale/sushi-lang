# Regression for #179, nested the other way: Result<Maybe<string>>.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: "ok = true"
# EXPECT_NO_LEAKS: true

fn mk() Maybe<string>:
    return Result.Ok(Maybe.Some("xxxxxxxxxxxx{'abcd'}"))

fn main() i32:
    let Result<Maybe<string>, StdError> r = mk()
    println("ok = {r.is_ok()}")
    return Result.Ok(0)
