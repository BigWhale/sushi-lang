# Use-after-move: a dynamic array passed by value is moved into the callee, so
# using it afterward is a use-after-move error.
# EXPECT_ERROR_CODE: CE2405

fn consume(i32[] arr) i32:
    return Result.Ok(arr.len())

fn run() i32:
    let i32[] data = from([1, 2, 3])
    let i32 n = consume(data)??
    # data was moved into consume() -- this reuse is illegal.
    let i32 again = consume(data)??
    return Result.Ok(again)

fn main() i32:
    let i32 r = run().realise(-1)
    return Result.Ok(0)
