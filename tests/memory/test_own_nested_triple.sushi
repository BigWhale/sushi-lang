# Test Own<Own<Own<T>>> - triple-nested owned pointers.
# Each Own.alloc moves its owning argument; the deep destructor frees every level
# exactly once (issue #106).
# EXPECT_STDOUT_EXACT: "7\n"
# EXPECT_RUNTIME_EXIT: 0
fn main() i32:
    let Own<i32> a = Own.alloc(7)
    let Own<Own<i32>> b = Own.alloc(a)
    let Own<Own<Own<i32>>> c = Own.alloc(b)
    let Own<Own<i32>> b2 = c.get()
    let Own<i32> a2 = b2.get()
    let i32 value = a2.get()
    println(value)
    return Result.Ok(value - 7)
