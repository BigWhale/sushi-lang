# Move-out on return (#134): a function builds an owning enum and returns it; the caller
# receives ownership and frees it once. Without the EnumType move-out branch the returned
# payload was freed before the caller used it (the returns-gap). No double-free, no leak.
# EXPECT_STDOUT_EXACT: "n=3\n"
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_NO_LEAKS: true

enum Msg:
    Text(string)
    Arr(i32[])

fn make() Msg:
    let Msg m = Msg.Arr(from([1, 2, 3]))
    return Result.Ok(m)

fn arr_len(Msg m) i32:
    match m:
        Msg.Arr(xs) ->
            return Result.Ok(xs.len())
        Msg.Text(_) ->
            return Result.Ok(0)

fn main() i32:
    let Msg msg = make().realise(Msg.Text("x"))
    let i32 n = arr_len(msg).realise(-1)
    println("n={n}")
    return Result.Ok(0)
