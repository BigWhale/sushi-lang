# Use-after-move (#134): an owning enum passed by value is moved into the callee;
# reusing the source is CE2405, and the diagnostic names the move site.
# EXPECT_ERROR_CODE: CE2405
# EXPECT_STDERR_CONTAINS: was moved here

enum Msg:
    Text(string)
    Arr(i32[])

fn consume(Msg m) i32:
    return Result.Ok(0)

fn main() i32:
    let Msg msg = Msg.Arr(from([1, 2, 3]))
    let i32 a = consume(msg).realise(-1)
    let i32 b = consume(msg).realise(-1)
    return Result.Ok(0)
