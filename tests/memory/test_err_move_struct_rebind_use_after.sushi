# Use-after-move (#134): rebinding an owning struct (let b = a) MOVES it; using the
# source afterward is CE2405.
# EXPECT_ERROR_CODE: CE2405
# EXPECT_STDERR_CONTAINS: was moved here

struct Buffer:
    i32[] data

fn main() i32:
    let Buffer a = Buffer(data: from([1, 2, 3]))
    let Buffer b = a
    let i32 n = a.data.len()
    return Result.Ok(0)
