# Move-by-value (#134): an owning struct passed by value is moved into the callee, which
# owns and frees it once; the caller does NOT free it again (no double-free, no leak).
# EXPECT_STDOUT_EXACT: "len=3\n"
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_NO_LEAKS: true

struct Buffer:
    i32[] data

fn total(Buffer b) i32:
    return Result.Ok(b.data.len())

fn main() i32:
    let Buffer buf = Buffer(data: from([1, 2, 3]))
    let i32 n = total(buf).realise(-1)
    println("len={n}")
    return Result.Ok(0)
