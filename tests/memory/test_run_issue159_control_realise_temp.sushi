# ANTI-DOUBLE-FREE CONTROL for #159 -- green before the fix, and it MUST stay green after it.
# .realise() on a TEMPORARY receiver ADOPTS the payload (it clones only for a BOUND receiver), so the
# payload already has exactly one owner. Destroying the temporary as well would double-free it.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: "v = "
# EXPECT_NO_LEAKS: true

fn mk() string:
    return Result.Ok("xxxxxxxxxxxx{'abcd'}")

fn probe() ~:
    let string v = mk().realise("fallback")
    println("v = {v}")
    return Result.Ok(~)

fn main() i32:
    probe()
    return Result.Ok(0)
