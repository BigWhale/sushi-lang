# Regression for #179: the leak was per-execution, not a one-shot allocation (10 iterations
# leaked exactly 10x the payload).
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: "9 ok = true"
# EXPECT_NO_LEAKS: true

fn mk() string:
    return Result.Ok("xxxxxxxxxxxx{'abcd'}")

fn main() i32:
    foreach(i in 0..10):
        let Result@(string, StdError) r = mk()
        println("{i} ok = {r.is_ok()}")
    return Result.Ok(0)
