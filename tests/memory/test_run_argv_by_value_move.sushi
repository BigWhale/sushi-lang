# main's `string[] args` is a BORROWED view of the process argv: its strings alias C
# memory and the array is not heap-owned by Sushi. Passing it by value to a function
# moves it, so the callee frees process argv at scope exit. Traps today (exit 133,
# SIGTRAP) with no diagnostic.
#
# The fix is a diagnostic -- moving `args` should not compile -- or a codegen change
# that keeps the borrow. Either way this program must not crash.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "3\n"
# CMD_ARGS: alpha beta

fn use_args(string[] a) i32:
    return Result.Ok(a.len())

fn main(string[] args) i32:
    println(use_args(args).realise(-1))
    return Result.Ok(0)
