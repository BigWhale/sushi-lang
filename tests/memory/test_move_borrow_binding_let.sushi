# #238 (#134 follow-up): a borrowed enum match-payload binding placed into a let-binding
# must be CLONED, not moved -- moving it out from under the still-live owner double-frees.
# EXPECT_STDOUT_EXACT: "n=3\n"
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_NO_LEAKS: true

enum Box:
    Full(i32[])
    Empty

enum Wrap:
    Has(Box)
    No

fn main() i32:
    let Wrap w = Wrap.Has(Box.Full(from([1, 2, 3])))
    let i32 n = 0
    match w:
        Wrap.Has(inner) ->
            let Box copy = inner
            match copy:
                Box.Full(xs) ->
                    n := xs.len()
                Box.Empty ->
                    n := -1
        Wrap.No ->
            n := -2
    println("n={n}")
    return Result.Ok(0)
