# EXPECT_STDOUT_EXACT: "a=2 b=2\n"
# EXPECT_RUNTIME_EXIT: 0
# TEST_TYPE: runtime
# Regression for #158: `.clone()` of an array whose elements are a recursive owning enum
# (the #139/#157 shape, a variant carrying a dynamic array) must deep-copy each element's
# heap payload. Before the fix the clone shallow-shared the payload and the process
# aborted at scope exit (double-free, exit 133).

enum Msg:
    Num(i32)
    Arr(Msg[])

fn run() i32:
    let Msg[] a = from([Msg.Arr(from([Msg.Num(1), Msg.Num(2)])), Msg.Num(3)])
    let Msg[] b = a.clone()
    println("a={a.len()} b={b.len()}")
    return Result.Ok(0)

fn main() i32:
    let i32 r = run().realise(1)
    return Result.Ok(r)
