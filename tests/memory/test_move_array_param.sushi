# Move-by-value: a dynamic-array parameter is moved into the callee (issue #131).
# The callee owns the array (methods, foreach, indexing all work) and frees it at
# scope exit; the inline `from([...])` argument form no longer crashes with CE0017.
# EXPECT_STDOUT_EXACT: "len=2\nsum=209\nfirst=104\nret=2\n"
# EXPECT_RUNTIME_EXIT: 0

fn describe(u8[] b) i32:
    let i32 total = 0
    foreach(x in b.iter()):
        total := total + (x as i32)
    println("len={b.len()}")
    println("sum={total}")
    println("first={b[0] as i32}")
    return Result.Ok(b.len())

fn main() i32:
    # Inline from([...]) argument -- the exact #131 repro shape.
    let i32 ret = describe(from([104 as u8, 105 as u8])).realise(-1)
    println("ret={ret}")
    return Result.Ok(0)
