# Use-after-move (#134): an owning struct moved in one if-branch is considered moved
# after the join, so a use past the branch is CE2405 (branch reconciliation).
# EXPECT_ERROR_CODE: CE2405
# EXPECT_STDERR_CONTAINS: was moved here

struct Buffer:
    i32[] data

fn consume(Buffer b) i32:
    return Result.Ok(b.data.len())

fn main() i32:
    let Buffer buf = Buffer(data: from([1, 2, 3]))
    if (buf.data.len() > 0):
        let i32 n = consume(buf).realise(-1)
    let i32 m = consume(buf).realise(-1)
    return Result.Ok(0)
