# Move-by-value (#134): placing an owning struct into an array literal moves it -- the
# array owns and frees it once; the source is consumed. No double-free, no leak.
# EXPECT_STDOUT_EXACT: "n=3\n"
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_NO_LEAKS: true

struct Buffer:
    i32[] data

fn main() i32:
    let Buffer a = Buffer(data: from([1, 2, 3]))
    let Buffer[] arr = from([a])
    println("n={arr[0].data.len()}")
    return Result.Ok(0)
