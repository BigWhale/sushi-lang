# #238 (#134 follow-up): a borrowed enum match-payload binding placed into a struct
# constructor field must be CLONED, not moved (the still-live owner keeps its copy).
# EXPECT_STDOUT_EXACT: "n=3\n"
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_NO_LEAKS: true

enum Box:
    Full(i32[])
    Empty

enum Wrap:
    Has(Box)
    No

struct Holder:
    Box b

fn main() i32:
    let Wrap w = Wrap.Has(Box.Full(from([1, 2, 3])))
    let i32 n = 0
    match w:
        Wrap.Has(inner) ->
            let Holder h = Holder(inner)
            match h.b:
                Box.Full(xs) ->
                    n := xs.len()
                Box.Empty ->
                    n := -1
        Wrap.No ->
            n := -2
    println("n={n}")
    return Result.Ok(0)
