# Use-after-move (#134): an owning struct passed by value is moved into the callee;
# reusing the source is CE2405, and the diagnostic names the move site.
# EXPECT_ERROR_CODE: CE2405
# EXPECT_STDERR_CONTAINS: was moved here

struct Buffer:
    i32[] data

fn consume(Buffer b) i32:
    return Result.Ok(b.data.len())

fn main() i32:
    let Buffer buf = Buffer(data: from([1, 2, 3]))
    let i32 a = consume(buf).realise(-1)
    let i32 b = consume(buf).realise(-1)
    return Result.Ok(0)
