# Regression for #159: the same unbound-temporary leak with an owning STRUCT payload rather than a
# string, proving the hole is not payload-specific -- it is the missing owner.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: "len = 8"
# EXPECT_NO_LEAKS: true

struct Box:
    i32[] data


fn mkbox() Box:
    return Result.Ok(Box(data: from([1, 2, 3, 4, 5, 6, 7, 8])))

fn main() i32:
    match mkbox():
        Result.Ok(b) -> println("len = {b.data.len()}")
        Result.Err(_) -> println("err")
    return Result.Ok(0)
