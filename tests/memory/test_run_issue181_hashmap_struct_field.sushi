# Regression for #181 under #134 move semantics: a HashMap@(string, i32) moved into a struct
# field must be destroyed by the struct's cleanup (the destructor dispatch needs a HashMap<
# branch, not the generic struct walk that mistook HashMap's `buckets` placeholder for a real
# i32[]). Owning (heap) string keys exercise the field destructor: every Entry key/value is
# freed exactly once, no leak (the map is a move type, so it moves in rather than cloning).
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: "count = 2"
# EXPECT_NO_LEAKS: true

use <collections/hashmap>

struct Holder:
    HashMap@(string, i32) m

fn main() i32:
    let HashMap@(string, i32) map = HashMap.new()
    map.insert("alpha-{'x'}", 1)
    map.insert("beta-{'y'}", 2)
    let Holder h = Holder(map)
    # map was MOVED into h; h owns and frees it at scope exit (no map.free()).
    println("count = {h.m.len()}")
    return Result.Ok(0)
