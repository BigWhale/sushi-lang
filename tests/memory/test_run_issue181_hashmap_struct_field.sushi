# Regression for #181: a HashMap<K,V> as a struct field ICE'd (CE0000) in the
# struct-constructor deep-copy path -- the clone/destructor dispatch had no HashMap<
# branch, so the generic struct walk hit HashMap's `buckets` DynamicArrayType placeholder
# and cloned it as a real i32[] against an Entry* value. Owning (heap) string keys
# exercise both the deep clone (independent buffers, no double-free) and the field
# destructor (frees every Entry key/value, no leak).
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: "count = 2"
# EXPECT_NO_LEAKS: true

use <collections/hashmap>

struct Holder:
    HashMap@(string, i32) m

fn main() i32:
    let HashMap@(string, i32) map = HashMap.new()
    map.insert("alpha-{'x'}", 1)
    map.insert("beta-{'y'}", 2)
    let Holder h = Holder(map)
    map.free()
    println("count = {h.m.len()}")
    return Result.Ok(0)
