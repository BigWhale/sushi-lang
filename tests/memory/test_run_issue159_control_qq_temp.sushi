# ANTI-DOUBLE-FREE CONTROL for #159 -- green before the fix, and it MUST stay green after it.
# `??` MOVES the payload out of the temporary to a new owner, which frees it exactly once. The
# temporary is clean today purely by OMISSION (it is invisible to every cleanup registry). A fix that
# blindly destroys every temporary would free this payload a second time. This cell is the tripwire.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_CONTAINS: "v = "
# EXPECT_NO_LEAKS: true

fn mk() string:
    return Result.Ok("xxxxxxxxxxxx{'abcd'}")

fn probe() ~:
    let string v = mk()??
    println("v = {v}")
    return Result.Ok(~)

fn main() i32:
    probe()
    return Result.Ok(0)
