# EXPECT_STDOUT_CONTAINS: i8:  -128
# EXPECT_STDOUT_CONTAINS: i16: -32768
# EXPECT_STDOUT_CONTAINS: i32: -2147483648
# EXPECT_STDOUT_CONTAINS: i64: -99999999
fn main() i32:
    let i8 a = -128 as i8
    let i16 b = -32768 as i16
    let i32 c = -2147483648
    let i64 d = -99999999 as i64

    println("i8:  {a}")
    println("i16: {b}")
    println("i32: {c}")
    println("i64: {d}")

    return Result.Ok(0)
