# EXPECT_STDOUT_CONTAINS: === Iterating over empty List ===
# EXPECT_STDOUT_CONTAINS: Done (should not print any numbers)
fn main() i32:
    let List<i32> empty = List.new()

    println("=== Iterating over empty List ===")
    foreach(n in empty.iter()):
        println(n)

    println("Done (should not print any numbers)")

    return Result.Ok(0)
