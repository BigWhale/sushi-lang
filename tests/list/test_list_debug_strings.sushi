# EXPECT_STDOUT_CONTAINS: List<string> {
# EXPECT_STDOUT_CONTAINS: charlie
fn main() i32:
    let List<string> names = List.new()

    # Push some strings
    names.push("alice")
    names.push("bob")
    names.push("charlie")

    println("=== List<string> Debug ===")
    names.debug()

    return Result.Ok(0)
