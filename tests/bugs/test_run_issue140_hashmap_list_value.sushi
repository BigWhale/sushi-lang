# Issue #140: HashMap with a List<T> value. get now deep-copies the List buffer out
# (_clone_list_value) and map.free frees it via the symmetric List branch added to the
# recursive destructor -- previously a List value leaked (no crash) because the generic
# struct destructor freed nothing for it.
# https://github.com/BigWhale/sushi-lang/issues/140
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "42\n"
use <collections/hashmap>

fn make_list() List<i32>:
    let List<i32> xs = List.new()
    xs.push(42)
    xs.push(43)
    return Result.Ok(xs)

fn first_of(Maybe<List<i32>> got) i32:
    match got:
        Maybe.Some(lst) ->
            match lst.get(0):
                Maybe.Some(v) ->
                    return Result.Ok(v)
                Maybe.None ->
                    return Result.Ok(-1)
        Maybe.None ->
            return Result.Ok(-2)

fn run() i32:
    let HashMap<i32, List<i32>> map = HashMap.new()
    let List<i32> xs = make_list()??   # named owning List local -> insert must MOVE it
    map.insert(5, xs)
    let i32 out = first_of(map.get(5))??
    map.free()
    return Result.Ok(out)

fn main() i32:
    println(run().realise(99))
    return Result.Ok(0)
