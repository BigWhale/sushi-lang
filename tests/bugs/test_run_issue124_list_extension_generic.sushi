# Issue #124: Extension methods on List<T> fail (generic form)
# https://github.com/BigWhale/sushi-lang/issues/124
# A generic `extend List<T>` used to crash the compiler with an uncaught
# TypeError (Param.__init__ got an unexpected keyword argument 'index'), and then
# hit the same CE0017 receiver mismatch as the concrete form.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "7\n"

extend List@(T) first_or(T dflt) T:
    return self.get(0).realise(dflt)

fn main() i32:
    let List@(i32) xs = List.new()
    xs.push(7)
    let i32 v = xs.first_or(0)
    println(v)
    return Result.Ok(0)
