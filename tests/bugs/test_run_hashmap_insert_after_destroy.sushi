# A HashMap destroyed through a &poke parameter has capacity 0 and null buckets.
# The borrow checker only marks a variable destroyed on a literal `m.destroy()` in
# the same function, so it does not see this one and CE2406 never fires (the hole is
# tracked separately). The insert then reached a probe loop with no limit: it masked
# the hash with (0 - 1) and indexed off the null bucket pointer, segfaulting.
# Now the probe is bounded by capacity, and an insert with nowhere to go traps.
# EXPECT_RUNTIME_EXIT: 1
# EXPECT_STDOUT_EXACT: ""
# EXPECT_STDERR_CONTAINS: RE2022
use <collections/hashmap>

fn wreck(&poke HashMap<string, i32> m) ~:
    m.destroy()
    return Result.Ok(~)

fn main() i32:
    let HashMap<string, i32> map = HashMap.new()
    map.insert("a", 1)
    wreck(&poke map)

    # Traps: no bucket to insert into. Must not segfault, must not print.
    map.insert("b", 2)
    println("unreachable")
    return Result.Ok(0)
