# Issue #119: Segfault reading trailing string field of a ??-unwrapped stdlib ProcessOutput
# https://github.com/BigWhale/sushi-lang/issues/119
# Reading the trailing `stderr_text` string of a `run()??` ProcessOutput as a bare
# println argument segfaulted (exit 139) due to a struct-layout mismatch on the ?? path.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "\ndone\n"
use <sys/process>
use <io/stdio>

fn work() i32 | ProcessError:
    let ProcessOutput out = run("echo", "hi")??
    println(out.stderr_text)          # empty (echo writes nothing to stderr)
    return Result.Ok(0)

fn main() i32:
    match work():
        Result.Ok(_) -> println("done")
        Result.Err(_) -> println("werr")
    return Result.Ok(0)
