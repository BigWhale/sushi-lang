# Issue #140: HashMap with an owning enum value (a variant carrying a dynamic array)
# double-freed on get + free the same way as the struct case. emit_value_clone now deep-copies
# the active variant's owning associated data out of the map on get.
# https://github.com/BigWhale/sushi-lang/issues/140
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "3\n"
use <collections/hashmap>

enum Status:
    Active
    Items(i32[])

fn len_of(Maybe@(Status) got) i32:
    match got:
        Maybe.Some(s) ->
            match s:
                Status.Items(arr) ->
                    return Result.Ok(arr.len())
                Status.Active ->
                    return Result.Ok(-1)
        Maybe.None ->
            return Result.Ok(-2)

fn run() i32:
    let HashMap@(i32, Status) map = HashMap.new()
    let i32[] xs = from([10, 20, 30])   # enum constructor must MOVE this named array arg
    map.insert(1, Status.Items(xs))
    let i32 out = len_of(map.get(1))??
    map.free()
    return Result.Ok(out)

fn main() i32:
    println(run().realise(99))
    return Result.Ok(0)
