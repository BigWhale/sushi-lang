# The remove() half of the same hole (see test_run_hashmap_insert_after_destroy).
# remove() on a map destroyed through a &poke parameter probed a null bucket array
# and segfaulted. Unlike insert(), remove has an honest answer when the probe finds
# nothing: the key is not there. It returns Maybe.None instead of trapping.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "not found\n"
use <collections/hashmap>

fn wreck(&poke HashMap<string, i32> m) ~:
    m.destroy()
    return Result.Ok(~)

fn main() i32:
    let HashMap<string, i32> map = HashMap.new()
    map.insert("a", 1)
    wreck(&poke map)

    let Maybe<i32> gone = map.remove("a")
    if (gone.is_some()):
        println("found {gone.realise(0)}")
    else:
        println("not found")

    return Result.Ok(0)
