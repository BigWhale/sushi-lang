# T1 safety: capturing an OWNED value (dynamic array / List / Own) needs move
# semantics + environment RAII (move-capture), which is deferred. A shallow env
# copy would alias the outer buffer (use-after-free if the closure escapes), so
# owned capture is rejected. Copy capture (primitives, strings) is allowed. CE2094.
# EXPECT_ERROR_CODE: CE2094
fn main() i32:
    let i32[] nums = from([1, 2, 3])
    let fn(i32) -> i32 f = |i32 x| x + nums.len()
    println(f(10).realise(0))
    return Result.Ok(0)
