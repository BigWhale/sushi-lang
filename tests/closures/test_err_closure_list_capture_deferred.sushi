# T1.5 scope: move-capture currently supports dynamic arrays. Capturing a List<T>
# (or Own<T> / a capturing closure) move-captures into the env correctly, but reading
# it back inside the lambda body (a method call on `__closure_env.<name>`) hits a
# lifted-body dispatch gap, so it is deferred with CE2094 rather than crashing.
# EXPECT_ERROR_CODE: CE2094
fn main() i32:
    let List<i32> xs = List.new()
    xs.push(10)
    let fn(i32) -> i32 f = |i32 x| x + xs.len()
    println(f(5).realise(-1))
    return Result.Ok(0)
