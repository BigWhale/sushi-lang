# T1.5 (item 1): move-capture of an owned List<T>. The list is moved into the closure's
# heap environment, which owns it and frees it via the env destructor at scope exit.
# Reading it back in the body (`xs.len()`) dispatches through the env-field member-access
# receiver path. xs has one element, so f(5) = 5 + 1 = 6.
# EXPECT_STDOUT_EXACT: "6\n"
fn run() i32:
    let List@(i32) xs = List.new()
    xs.push(10)
    let fn(i32) -> i32 f = |i32 x| x + xs.len()
    return Result.Ok(f(5)??)

fn main() i32:
    println(run().realise(-1))
    return Result.Ok(0)
