# T1.5 (item 2b): pulling a closure back OUT of a container that owns it is a
# NON-owning borrow -- the List remains the sole owner. `let g = fns.get(0)??` does not
# register a second owner, so List.free() frees each closure env exactly once (no
# double free). g(10) = 10 + base(100) = 110.
# EXPECT_STDOUT_EXACT: "110\n"
fn run() i32:
    let i32 base = 100
    let List@(fn(i32) -> i32) fns = List.new()
    fns.push(|i32 x| x + base)
    let fn(i32) -> i32 g = fns.get(0)??
    let i32 r = g(10)??
    fns.free()
    return Result.Ok(r)

fn main() i32:
    println(run().realise(-1))
    return Result.Ok(0)
