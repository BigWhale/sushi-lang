# T1.5 (item 1): a move-captured List<T> is mutable inside the closure body. The env
# owns the list across calls, so a mutating method (`xs.push`) on the env-field receiver
# persists. Start [10]; f(5) -> [10,5] len 2; f(9) -> [10,5,9] len 3; 2 + 3 = 5.
# EXPECT_STDOUT_EXACT: "5\n"
fn run() i32:
    let List<i32> xs = List.new()
    xs.push(10)
    let fn(i32) -> i32 f = |i32 x|:
        xs.push(x)
        return Result.Ok(xs.len())
    let i32 a = f(5)??
    let i32 b = f(9)??
    return Result.Ok(a + b)

fn main() i32:
    println(run().realise(-1))
    return Result.Ok(0)
