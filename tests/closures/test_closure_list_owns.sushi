# T1.5: a List<fn(...)> owns the closures stored in it. Two capturing closures are
# pushed (each with its own heap environment); List.free() recursively destroys the
# elements, freeing each closure's environment through its type-erased drop pointer.
# The list is the sole owner, so there is exactly one free per environment.
# EXPECT_STDOUT_EXACT: "2\n"
fn build() i32:
    let i32 base = 100
    let List@(fn(i32) -> i32) fns = List.new()
    fns.push(|i32 x| x + base)
    fns.push(|i32 x| x * base)
    let i32 n = fns.len()
    fns.free()
    return Result.Ok(n)

fn main() i32:
    println(build().realise(-1))
    return Result.Ok(0)
