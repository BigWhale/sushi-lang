# T1.5: move-capture consumes the outer binding. An owned value (dynamic array) is
# moved into the closure's environment, so using the outer `nums` after the capture
# is a use-after-move (CE2405). Copy captures (primitives/strings) stay usable; only
# owned captures move.
# EXPECT_ERROR_CODE: CE2405
fn main() i32:
    let i32[] nums = from([1, 2, 3])
    let fn(i32) -> i32 f = |i32 x| x + nums.len()
    println(nums.len())
    return Result.Ok(0)
