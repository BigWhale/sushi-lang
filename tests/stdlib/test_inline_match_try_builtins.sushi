# Inline match / ?? directly on a stdlib builtin returning Result/Maybe (Bug A).
# Previously these failed with CE0055 / 'undefined name' unless bound to a let first.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_STDOUT_EXACT: "cwd branch: /Users/bigwhale/Projects/sushi\nenv none branch\nlast l at 3\nread: /Users/bigwhale/Projects/sushi\ninline builtins ok\n"

use <sys/process>
use <sys/env>
use <collections/strings>

fn read_cwd() string | ProcessError:
  let string cwd = getcwd()??
  return Result.Ok(cwd)

fn main() i32:
  # Inline match on a builtin returning Result<string>.
  match getcwd():
    Result.Ok(path) -> println("cwd branch: {path}")
    Result.Err(_) -> println("cwd err branch")

  # Inline match on a builtin returning Maybe<string> (None branch is taken here).
  match getenv("NoSuchVar_Sushi"):
    Maybe.Some(v) -> println("env has: {v}")
    Maybe.None() -> println("env none branch")

  # Inline match on a string method returning Maybe<i32> (.find_last, was CE0055).
  let string s = "hello"
  match s.find_last("l"):
    Maybe.Some(idx) -> println("last l at {idx}")
    Maybe.None() -> println("no l")

  # Inline ?? through a wrapper whose error type matches the builtin's.
  let string c = read_cwd().realise("none")
  println("read: {c}")

  println("inline builtins ok")
  return Result.Ok(0)
