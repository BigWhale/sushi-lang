# Guards Tier 4.6: a `match` whose scrutinee is a stdlib call.
#
# Pass 2 now types stdlib calls from the stdlib registry and stamps
# resolved_scrutinee_type on the match. It used to hardcode a lookup of a one-arg
# "Result<i32>" enum, a name that is never registered (the canonical name is two-arg,
# Result<T, E>), so the lookup always missed and the backend re-derived the scrutinee
# type instead -- and a miss there silently drops the pattern bindings.
# EXPECT_STDOUT_EXACT: "slept: 0\n"
use <time>

fn main() i32:
    match msleep(1 as i64):
        Result.Ok(code) ->
            println("slept: {code}")
        Result.Err(_) ->
            println("error")

    return Result.Ok(0)
