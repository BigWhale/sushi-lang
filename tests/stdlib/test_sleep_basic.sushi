# EXPECT_STDOUT_EXACT: "Testing basic sleep for 1 second...\nSleep completed successfully\nSleep was not interrupted\n"
# EXPECT_RUNTIME_EXIT: 0
use <time>

fn run_test() i32:
    println("Testing basic sleep for 1 second...")
    let i32 result = sleep(1 as i64)??
    println("Sleep completed successfully")

    if (result == 0):
        println("Sleep was not interrupted")
    else:
        println("Sleep was interrupted")

    return Result.Ok(0)

fn main() i32:
    let i32 result = run_test().realise(99)
    return Result.Ok(result)
