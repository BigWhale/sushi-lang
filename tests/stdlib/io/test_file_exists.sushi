# EXPECT_STDOUT_EXACT: "OK: exists() works correctly\n"
# EXPECT_RUNTIME_EXIT: 0
use <io/files>

fn main() i32:
    # Self-contained: create a known file so the test does not depend on the
    # current working directory or on this test's own location in the tree.
    match open("/tmp/sushi_r108_exists.txt", FileMode.Write()):
        FileResult.Ok(f) ->
            f.close()
        FileResult.Err(_) ->
            println("ERROR: could not create test file")
            return Result.Ok(1)

    if (not exists("/tmp/sushi_r108_exists.txt")):
        println("ERROR: File should exist")
        return Result.Ok(1)

    if (exists("/tmp/nonexistent_file_12345.txt")):
        println("ERROR: File should not exist")
        return Result.Ok(1)

    println("OK: exists() works correctly")
    return Result.Ok(0)
