# Test perk constraint violation for generic enums
# EXPECT_ERROR_CODE: CE4006
# NoHash struct does NOT implement Hashable, so instantiating
# Box<NoHash> should fail with CE4006

perk Hashable:
    fn hash() u64

struct NoHash:
    i32 value

enum Box@(T: Hashable):
    Empty
    Full(T)

fn main() i32:
    let NoHash nh = NoHash(42)

    # This should fail with CE4006 - NoHash does not implement Hashable
    let Box@(NoHash) b = Box.Full(nh)

    return Result.Ok(0)
