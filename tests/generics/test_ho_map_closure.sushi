# Generic higher-order function: map<T, U>(List<T>, fn(T) -> U) applied with a CAPTURING
# closure (captures `factor`). Exercises Gap C (infer T from List<i32>, U from the fn
# return) + Gap A (substitute fn(T)->U during monomorphization) + the closures indirect
# call. [1,2,3] * 10 -> [10,20,30]; element 2 is 30.
# EXPECT_STDOUT_EXACT: "30\n"
fn map@(T, U)(List@(T) xs, fn(T) -> U f) List@(U):
    let List@(U) out = List.new()
    foreach(x in xs.iter()):
        out.push(f(x)??)
    return Result.Ok(out)

fn run() i32:
    let i32 factor = 10
    let List@(i32) xs = List.new()
    xs.push(1)
    xs.push(2)
    xs.push(3)
    let List@(i32) ys = map(xs, |i32 x| x * factor)??
    return Result.Ok(ys.get(2).realise(-1))

fn main() i32:
    println(run().realise(-1))
    return Result.Ok(0)
