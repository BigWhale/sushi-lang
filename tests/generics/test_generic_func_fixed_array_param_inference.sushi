# Test: generic function inferring element type T from a fixed-size T[N] parameter (issue #137 part 1)
# Inference unifies a T[3] parameter position against a concrete i32[3] argument.
# EXPECT_STDOUT_EXACT: "10\n"

fn head3<T>(T[3] arr) T:
    return Result.Ok(arr[0])

fn run_test() i32:
    let i32[3] nums = [10, 20, 30]
    let i32 h = head3(nums).realise(99)
    println("{h}")
    return Result.Ok(0)

fn main() i32:
    let i32 result = run_test().realise(99)
    return Result.Ok(result)
