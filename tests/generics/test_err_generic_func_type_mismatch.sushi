# Test: Type mismatch after inference should fail. identity(42) infers i32 through the
# ?? unwrap, so the bad assignment is caught at the front end (CE2002) rather than as a
# backend cast failure.
# EXPECT_ERROR_CODE: CE2002

fn identity@(T)(T x) T:
    return Result.Ok(x)

fn run_test() i32:
    # Error: identity(42) returns i32, can't assign to string
    let string s = identity(42)??
    return Result.Ok(0)

fn main() i32:
    let i32 result = run_test().realise(99)
    return Result.Ok(result)
