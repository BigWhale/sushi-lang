# Regression for #135 (residual): Own.alloc(<inline generic-enum constructor>) failed with
# CE0113 because Own<T>'s field is T* (a PointerType) and propagate_types_to_value has no
# PointerType branch, so the expected element type was dropped and resolved_enum_type was
# never set on the constructor. The original #135 infinite loop was already fixed; this is
# the different bug the repro now surfaces.
# EXPECT_RUNTIME_EXIT: 0
# EXPECT_NO_LEAKS: true
# EXPECT_STDOUT_CONTAINS: "v = 42"

enum Box<T>:
    Val(T)

fn main() i32:
    let Own<Box<i32>> t = Own.alloc(Box.Val(42))
    let Box<i32> b = t.get()
    match b:
        Box.Val(v) -> println("v = {v}")
    t.destroy()
    return Result.Ok(0)
