# T2.3: pass a generic-fn reference into a higher-order function via a typed binding.
# `let fn(i32) -> i32 id = identity` fixes the instantiation, then map(xs, id) applies it.
# map([5, 7], identity) -> [5, 7]; element 1 is 7.
# EXPECT_STDOUT_EXACT: "7\n"
use <collections/iter>

fn identity<T>(T x) T:
    return Result.Ok(x)

fn run() i32:
    let fn(i32) -> i32 id = identity
    let List<i32> xs = List.new()
    xs.push(5)
    xs.push(7)
    let List<i32> ys = map(xs, id)??
    return Result.Ok(ys.get(1).realise(-1))

fn main() i32:
    println(run().realise(-1))
    return Result.Ok(0)
