# Guards PLAN.md T2.5: monomorphize_enum writes its cache entry only AFTER
# substituting every field, so a self-referential field re-enters and blows the
# Python stack. Today this dumps a raw RecursionError traceback and exits 1.
# The compiler must instead report a CE-coded diagnostic and exit 2.
# The exact code is chosen when T2.5 lands; add EXPECT_ERROR_CODE then.

enum Tree<T>:
    Leaf
    Node(Own<Tree<T>>)

fn main() i32:
    let Tree<i32> t = Tree.Leaf()
    match t:
        Tree.Leaf() ->
            println("Mostly Harmless")
        Tree.Node(_) ->
            println("node")
    return Result.Ok(0)
