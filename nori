#!/usr/bin/env bash
set -euo pipefail

# Capture the original working directory
ORIGINAL_CWD="$(pwd)"

# Get the directory where nori is located (the sushi project root)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Change to the sushi project directory to ensure Python can find the module
cd "$SCRIPT_DIR"

# Run nori; __main__.py restores NORI_CWD and exits with main()'s return code.
# (The old inline `python -c "... main()"` snippet discarded that return code,
# so ./nori exited 0 even when a command failed.)
exec env NORI_CWD="$ORIGINAL_CWD" uv run --frozen --active python -m sushi_lang.packager "$@"
