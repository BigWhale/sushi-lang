# The closure returned from make_adder captures `n` and outlives make_adder's
# own frame -- the environment is heap-allocated, so this is safe.
fn make_adder(i32 n) fn(i32) -> i32:
    return Result.Ok(|i32 x| x + n)

fn use_adder() i32:
    let fn(i32) -> i32 add5 = make_adder(5)??
    return Result.Ok(add5(10)??)

fn main() i32:
    println(use_adder().realise(0))    # 15
    return Result.Ok(0)
