use <collections/iter>

fn main() i32:
    let i32 minimum = 42
    let List@(i32) readings = List.new()
    readings.push(10)
    readings.push(42)
    readings.push(99)
    readings.push(7)
    # Keep only the improbability readings that clear the threshold.
    let List@(i32) high = filter(readings, |i32 r| r >= minimum).realise(List.new())
    println(high.len())
    return Result.Ok(0)
