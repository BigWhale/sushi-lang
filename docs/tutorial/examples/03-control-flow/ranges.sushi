fn main() i32:
    println("Exclusive 0..5:")
    foreach(i in 0..5):
        println("  {i}")

    println("Inclusive 1..=3:")
    foreach(i in 1..=3):
        println("  {i}")

    println("Descending 3..0:")
    foreach(i in 3..0):
        println("  {i}")

    println("Over a list:")
    let string[] crew = from(["Arthur", "Ford", "Trillian"])
    foreach(name in crew.iter()):
        println("  {name}")

    return Result.Ok(0)
